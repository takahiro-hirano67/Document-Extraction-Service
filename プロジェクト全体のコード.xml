# 有効にするルール
select = [
    "F",   # Pyflakes (未定義・未使用の変数やインポート)
    "E",   # pycodestyle Error (スタイルガイド(PEP8)に沿っているか)
    "W",   # pycodestyle Warning (スタイルガイド(PEP8)に沿っているか)
    "I",   # isort (import順序の最適化)
    "N",   # pep8-naming (関数や変数の命名がスタイルガイド(PEP8)に従っているか)
    "D",   # pydocstyle (ドキュメンテーション文字列(Docstring)に関するルール)
    "UP",  # pyupgrade (新しいPython記法への自動アップデート)
    "B",   # flake8-bugbear (バグになりやすい問題や設計上の問題を検出)
    "S",   # flake8-bandit (evalなどの安全ではないコードを検出)
    "SIM", # flake8-simplify (コードをシンプルにできる箇所の指摘 | ネストされたif文など)
    "ANN", # flake8-annotations (型ヒントに関するルール)
    "TCH",  # flake8-type-checking (型チェック用インポートの最適化)
]

# 無視するルール
ignore = [
    "E501", # 1行あたりの行の長さのルール (Formatterに任せるためLintでは無視)
    "B008", # デフォルト引数で関数呼び出しをしないルール (FastAPIのQuery()と競合するため無効)
    "D203", # クラス定義の前に空行を入れるルール (D211(クラス定義の前に空行を入れてはいけないルール)と競合するため無効)
    "D213", # Docstringの要約行の位置を2行目にするルール (D212(要約行の位置を1行目にするルール)と競合するため無効)
    "D400", # Docstringの1行目にピリオドを付けるルール (日本語の文章と競合するため無効)
    "D415", # Docstringの1行目の末尾に符号を付けるルール（日本語の文章と競合するため無効）
]

# --- 特定のファイルだけルールを無視する設定 ---
[tool.ruff.lint.per-file-ignores]
"__init__.py" = ["F401"] # __init__.py では「未使用のimport」を許可する
"src/tests/**/**/*.py" = ["S101", "ANN"] # テストコードでは assert の使用を許可する (banditルールのS101)

# --- Ruffによるフォーマットの設定 ---
[tool.ruff.format]
# ダブルクォーテーションに統一
quote-style = "double"
# インデントはスペース
indent-style = "space"

# --- pytestの設定 ---
[tool.pytest.ini_options]
# テスト実行時にプロジェクトルートをモジュール検索パス(sys.path)に追加する
# テストコード内から絶対パスインポートが可能になる
pythonpath = ["."]

# pytestがデフォルトでテストを認識するディレクトリを指定
testpaths = ["src/tests"]

# テストID（parametrize等で指定する文字列）のUnicodeエスケープを無効化する
# テスト結果出力時の日本語が文字化けして表示されるのを防ぐ
disable_test_id_escaping_and_forfeit_all_rights_to_community_support = true
</file>

